{
  "version": 2,
  "builds": [
    {
      "src": "api_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api_server.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "OLLAMA_URL": "@ollama_url",
    "REDIS_URL": "@redis_url"
  },
  "regions": ["iad1", "sfo1", "fra1"]
}
